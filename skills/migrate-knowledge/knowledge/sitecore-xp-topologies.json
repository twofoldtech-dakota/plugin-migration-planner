        "cm_cd_combined": {
          "description": "Combined Content Management and Content Delivery",
          "typical_count": 1,
          "min_spec": { "cpu": 4, "ram_gb": 16, "disk_gb": 100 },
          "recommended_spec": { "cpu": 8, "ram_gb": 32, "disk_gb": 200 },
          "azure_vm_series": "D8s_v5 or E8s_v5"
        }
      },
      "databases": {
        "core": { "description": "Sitecore Core database", "typical_size_gb": "1-5" },
        "master": { "description": "Content authoring database", "typical_size_gb": "5-50" },
        "web": { "description": "Published content database", "typical_size_gb": "5-50" }
      },
      "services": ["Solr"],
      "license_roles": ["Standalone"]
    },
