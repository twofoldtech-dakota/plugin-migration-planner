  "common_services": {
    "solr": {
      "description": "Apache Solr provides search functionality for Sitecore content and xDB",
      "versions_supported": { "sitecore_10.0-10.1": "8.4+", "sitecore_10.2+": "8.8+" },
      "deployment_options": ["Standalone", "SolrCloud"],
      "azure_options": ["Solr on Azure VM", "Solr on AKS", "Azure Cognitive Search (with Sitecore module)"]
    },
    "redis": {
      "description": "Redis provides session state, output cache, and Sitecore caching",
      "usage_in_sitecore": ["Session State Provider", "Output Cache", "Private Session State (xConnect)"],
      "azure_options": ["Azure Cache for Redis (Premium or Enterprise)"]
    },
    "identity_server": {
      "description": "Sitecore Identity Server handles authentication for CM and other roles",
